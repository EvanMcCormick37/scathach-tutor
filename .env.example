# =============================================================================
# scathach — Environment Configuration
# =============================================================================
#
# Copy this file to .env and fill in your values:
#   cp .env.example .env
#
# HOW TO GET A FREE OPENROUTER API KEY:
#   1. Go to https://openrouter.ai and sign up (no credit card required)
#   2. Navigate to https://openrouter.ai/keys and click "Create Key"
#   3. Copy the key (starts with "sk-or-v1-...") and paste it below
#
# The default model (Kimi-K2) is free on OpenRouter's free tier.
# If Kimi-K2 is unavailable, switch to SCATHACH_MODEL=arcee-ai/arcee-blaze
# or SCATHACH_MODEL=google/gemini-flash-1.5 as fallbacks.
# =============================================================================

# Required: Your OpenRouter API key
SCATHACH_OPENROUTER_API_KEY=sk-or-v1-your-key-here

# Optional: LLM model to use (default: moonshotai/kimi-k2)
# SCATHACH_MODEL=moonshotai/kimi-k2
# SCATHACH_MODEL=arcee-ai/arcee-blaze
# SCATHACH_MODEL=google/gemini-flash-1.5

# Optional: Minimum score to pass a question (5–10, default: 7)
# SCATHACH_QUALITY_THRESHOLD=7

# Optional: Default timing for learning sessions (timed or untimed, default: untimed)
# SCATHACH_MAIN_TIMING=untimed

# Optional: Default timing for review sessions (timed or untimed, default: untimed)
# SCATHACH_REVIEW_TIMING=untimed

# Optional: Path to the SQLite database (default: ~/.scathach/scathach.db)
# SCATHACH_DB_PATH=~/.scathach/scathach.db

# Optional: Enable Hydra Protocol during super-review sessions (default: false)
# SCATHACH_HYDRA_IN_SUPER_REVIEW=false

# Optional: Automatically open the source document at session/review start (default: false)
# Uses your OS default application for the file type (e.g. your PDF viewer for .pdf files)
# SCATHACH_OPEN_DOC_ON_SESSION=false
